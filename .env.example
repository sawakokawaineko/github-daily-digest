# bin/digest.sh が参照する環境変数のサンプル。
# 実際の値で .env を作成し、`set -a; source .env; set +a` 等で読み込んでから実行する。

# fine-grained PAT。権限: repo読、read:user、read:org / 期限1年
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Incoming Webhook URL（DM宛）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 集計対象の GitHub ユーザー名
GITHUB_USERNAME=azimicat

# Slack送信を行うときは false に明示的に切り替える
DRY_RUN=true

# 0件のとき通知スキップ（false にすると「本日活動なし」を通知する）
SKIP_IF_EMPTY=false
